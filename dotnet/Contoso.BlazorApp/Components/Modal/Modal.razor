@implements IDisposable
@inject IJSRuntime JS

@if (IsOpen)
{
    <div class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50" @onclick="HandleBackdropClick" @onclick:stopPropagation="false">
        <div class="bg-white dark:bg-gray-900 rounded-lg p-6 min-w-300 max-w-90 max-h-90vh overflow-y-auto shadow-xl" @onclick="HandleContentClick" @onclick:stopPropagation="true">
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen)
        {
            await JS.InvokeVoidAsync("eval", "document.body.style.overflow = 'hidden'");
        }
        else
        {
            await JS.InvokeVoidAsync("eval", "document.body.style.overflow = 'auto'");
        }
    }

    private async Task HandleBackdropClick()
    {
        await OnClose.InvokeAsync();
    }

    private void HandleContentClick()
    {
        // Prevent click from bubbling to backdrop
    }

    public void Dispose()
    {
        // Reset body overflow when component is disposed
        _ = JS.InvokeVoidAsync("eval", "document.body.style.overflow = 'auto'");
    }
}
